# India Cricket Dashboard — Environment Variables
# Copy this file to .env and fill in your values

# Server
PORT=3000

# Cron schedule (default: 7:00 AM IST = 01:30 UTC)
# Format: "minute hour * * *" in UTC
CRON_TIME=30 1 * * *

# Set to "true" to disable the cron scheduler (useful for standalone sync script)
DISABLE_CRON=false

# Anthropic API Key — used ONLY for AI fallback (not routine scraping)
# Get yours at: https://console.anthropic.com/
# Leave empty to disable AI features — scraper will still work
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Playwright browser path (optional — if using system Chromium)
# PLAYWRIGHT_CHROMIUM_PATH=/usr/bin/chromium-browser

# Node environment
NODE_ENV=production
