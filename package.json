{
  "name": "bcci-schedule",
  "version": "1.0.0",
  "description": "India Cricket Dashboard — BCCI schedule tracker for Men's & Women's teams",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "sync": "node scripts/sync.js",
    "export": "node scripts/export-static.js",
    "sync-and-export": "npm run sync && npm run export",
    "setup": "node -e \"require('./src/db/db').getDb(); console.log('Database initialized');\"",
    "test": "echo \"No tests configured\" && exit 0"
  },
